# Supabase Service Role Key (server-side only — NEVER expose in frontend)
# Get from: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Tally Data Export Sync (for sync-tally-export.js)
# Set this to the VPN-mounted folder path where Tally exports XML files
# Windows:  TALLY_EXPORT_DIR=Z:\DataExport
# macOS:    TALLY_EXPORT_DIR=/Volumes/DataExport
# Linux:    TALLY_EXPORT_DIR=/mnt/tally-export
TALLY_EXPORT_DIR=./tally-exports

# OpenAI Configuration for AI features
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Double Tick WhatsApp API Configuration (for automated notifications)
DOUBLETICK_API_KEY=your_doubletick_api_key_here
DOUBLETICK_PHONE=your_hospital_phone_number_here

# Claude Code Auto-Confirm Configuration (optional)
# Uses file-based config by default (.claude/auto-confirm-config.json)
# AUTO_CONFIRM_ENABLED=false
# AUTO_CONFIRM_AGENT=auto-confirm

# Development settings for Claude Code extensions
# NODE_ENV=development
# DEBUG=claude-code:auto-confirm